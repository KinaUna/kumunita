@inject CommunityContext CommunityContext
@inject AuthenticationStateProvider Auth
@implements IDisposable

<MudNavMenu>
    <AuthorizeView>

        <!-- ── Unauthenticated ──────────────────────────────────────── -->
        <NotAuthorized>
            <MudNavLink Href="/"       Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/about"  Icon="@Icons.Material.Filled.Info">About</MudNavLink>
            <MudNavLink Href="/authentication/login"
                        Icon="@Icons.Material.Filled.Login">Sign in</MudNavLink>
        </NotAuthorized>

        <!-- ── Authenticated ───────────────────────────────────────── -->
        <Authorized>

            @if (CommunityContext.IsInCombinedView)
            {
                <!-- Combined view: no active community -->
                <MudNavLink Href="/announcements"
                            Icon="@Icons.Material.Filled.Announcement">
                    Announcements
                </MudNavLink>
                <MudNavLink Href="/communities"
                            Icon="@Icons.Material.Filled.LocationCity">
                    My Communities
                </MudNavLink>
            }
            else
            {
                string slug = CommunityContext.ActiveSlug!;

                <!-- Community-scoped navigation -->
                <MudNavLink Href="@($"/announcements/{slug}")"
                            Icon="@Icons.Material.Filled.Announcement">
                    Announcements
                </MudNavLink>
                <MudNavLink Href="@($"/directory/{slug}")"
                            Icon="@Icons.Material.Filled.People">
                    Directory
                </MudNavLink>
                <MudNavLink Href="@($"/profile/{slug}")"
                            Icon="@Icons.Material.Filled.Person">
                    My Profile
                </MudNavLink>
                <MudNavLink Href="/communities"
                            Icon="@Icons.Material.Filled.LocationCity">
                    Communities
                </MudNavLink>

                <!-- Moderator+ section -->
                @if (_user?.IsModeratorOrAbove(slug) == true)
                {
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="@($"/communities/{slug}/members")"
                                Icon="@Icons.Material.Filled.ManageAccounts">
                        Members &amp; Invitations
                    </MudNavLink>
                    <MudNavLink Href="@($"/communities/{slug}/moderation")"
                                Icon="@Icons.Material.Filled.FactCheck">
                        Moderation Queue
                    </MudNavLink>
                }

                <!-- Manager-only section -->
                @if (_user?.IsManagerOf(slug) == true)
                {
                    <MudNavLink Href="@($"/communities/{slug}/manage")"
                                Icon="@Icons.Material.Filled.Settings">
                        Community Settings
                    </MudNavLink>
                }
            }

            <!-- Platform admin section — always visible if applicable -->
            @if (_user?.IsPlatformAdmin() == true)
            {
                <MudDivider Class="my-2" />
                <MudNavLink Href="/platform"
                            Icon="@Icons.Material.Filled.AdminPanelSettings">
                    Platform Admin
                </MudNavLink>
            }

        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private System.Security.Claims.ClaimsPrincipal? _user;

    protected override async Task OnInitializedAsync()
    {
        CommunityContext.OnChange += OnCommunityChanged;
        AuthenticationState state = await Auth.GetAuthenticationStateAsync();
        _user = state.User;
    }

    private void OnCommunityChanged() => StateHasChanged();

    public void Dispose() =>
        CommunityContext.OnChange -= OnCommunityChanged;
}
