@page
@model Kumunita.Host.Pages.Account.ResendConfirmationModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Resend confirmation – Kumunita</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, sans-serif;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 16px rgba(0,0,0,.1);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 400px;
        }
        h1 { font-size: 1.5rem; margin-bottom: 1.5rem; text-align: center; }
        .field { margin-bottom: 1rem; }
        label { display: block; font-size: .875rem; font-weight: 600; margin-bottom: .25rem; }
        input[type=email] {
            width: 100%; padding: .5rem .75rem;
            border: 1px solid #ccc; border-radius: 4px;
            font-size: 1rem;
        }
        input[type=email]:focus {
            outline: 2px solid #1976d2; border-color: #1976d2;
        }
        .success {
            background: #e8f5e9; color: #2e7d32;
            border: 1px solid #c8e6c9; border-radius: 4px;
            padding: .75rem 1rem; margin-bottom: 1rem; font-size: .875rem;
        }
        button[type=submit] {
            width: 100%; padding: .65rem;
            background: #1976d2; color: #fff;
            border: none; border-radius: 4px;
            font-size: 1rem; font-weight: 600;
            cursor: pointer; margin-top: 1.25rem;
        }
        button[type=submit]:hover { background: #1565c0; }
        .back-link {
            display: block; text-align: center;
            margin-top: 1rem; font-size: .875rem;
            color: #1976d2; text-decoration: none;
        }
        .back-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Resend confirmation email</h1>

        @if (Model.EmailSent)
        {
            <div class="success">
                If that email address is registered and unconfirmed, a new confirmation link has been sent.
                Please check your inbox.
            </div>
        }

        <form method="post">
            <div class="field">
                <label asp-for="Input.Email">Email address</label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" style="color:#c62828;font-size:.8rem"></span>
            </div>

            <button type="submit">Send confirmation link</button>
        </form>

        <a class="back-link" href="/Account/Login">Back to sign in</a>
    </div>
</body>
</html>
