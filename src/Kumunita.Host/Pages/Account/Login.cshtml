@page
@model Kumunita.Host.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in – Kumunita</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, sans-serif;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 16px rgba(0,0,0,.1);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 400px;
        }
        h1 { font-size: 1.5rem; margin-bottom: 1.5rem; text-align: center; }
        .field { margin-bottom: 1rem; }
        label { display: block; font-size: .875rem; font-weight: 600; margin-bottom: .25rem; }
        input[type=email], input[type=password] {
            width: 100%; padding: .5rem .75rem;
            border: 1px solid #ccc; border-radius: 4px;
            font-size: 1rem;
        }
        input[type=email]:focus, input[type=password]:focus {
            outline: 2px solid #1976d2; border-color: #1976d2;
        }
        .remember { display: flex; align-items: center; gap: .5rem; font-size: .875rem; }
        .error {
            background: #fdecea; color: #c62828;
            border: 1px solid #f5c6cb; border-radius: 4px;
            padding: .75rem 1rem; margin-bottom: 1rem; font-size: .875rem;
        }
        button[type=submit] {
            width: 100%; padding: .65rem;
            background: #1976d2; color: #fff;
            border: none; border-radius: 4px;
            font-size: 1rem; font-weight: 600;
            cursor: pointer; margin-top: 1.25rem;
        }
        button[type=submit]:hover { background: #1565c0; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Sign in to Kumunita</h1>

        @if (Model.ErrorMessage is not null)
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="error" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="field">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" autocomplete="username" />
                <span asp-validation-for="Input.Email" style="color:#c62828;font-size:.8rem"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" style="color:#c62828;font-size:.8rem"></span>
            </div>

            <div class="field remember">
                <input asp-for="Input.RememberMe" type="checkbox" />
                <label asp-for="Input.RememberMe">Remember me</label>
            </div>

            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>